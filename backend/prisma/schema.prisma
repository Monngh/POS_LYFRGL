generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Branch {
  id            Int           @id @default(autoincrement())
  name          String
  address       String?
  phone         String?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bankDeposits  BankDeposit[]
  cashSessions  CashSession[]
  inventories   Inventory[]
  kardexEntries Kardex[]
  sales         Sale[]
  users         User[]
}

model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  passwordHash  String
  pinCode       String?
  name          String
  role          String
  active        Boolean       @default(true)
  branchId      Int
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  cashSessions  CashSession[]
  kardexEntries Kardex[]
  sales         Sale[]
  branch        Branch        @relation(fields: [branchId], references: [id], onUpdate: NoAction)
}

model Product {
  id                Int                @id @default(autoincrement())
  sku               String             @unique
  barcode           String?            @unique
  name              String
  description       String?
  costPrice         Decimal            @db.Decimal(18, 2)
  sellPrice         Decimal            @db.Decimal(18, 2)
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  inventories       Inventory[]
  kardexEntries     Kardex[]
  promotionProducts PromotionProduct[]
  saleDetails       SaleDetail[]
}

model Inventory {
  id        Int     @id @default(autoincrement())
  productId Int
  branchId  Int
  quantity  Int     @default(0)
  minStock  Int     @default(5)
  maxStock  Int     @default(100)
  branch    Branch  @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  product   Product @relation(fields: [productId], references: [id], onUpdate: NoAction)

  @@unique([productId, branchId])
}

model Kardex {
  id             Int      @id @default(autoincrement())
  productId      Int
  branchId       Int
  userId         Int
  quantityChange Int
  balanceAfter   Int
  movementType   String
  reason         String?
  createdAt      DateTime @default(now())
  branch         Branch   @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  product        Product  @relation(fields: [productId], references: [id], onUpdate: NoAction)
  user           User     @relation(fields: [userId], references: [id], onUpdate: NoAction)
}

model CashSession {
  id             Int           @id @default(autoincrement())
  branchId       Int
  userId         Int
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  initialAmount  Decimal       @db.Decimal(18, 2)
  expectedAmount Decimal       @db.Decimal(18, 2)
  declaredAmount Decimal?      @db.Decimal(18, 2)
  difference     Decimal?      @db.Decimal(18, 2)
  cashIn         Decimal       @default(0) @db.Decimal(18, 2)
  cashOut        Decimal       @default(0) @db.Decimal(18, 2)
  status         String        @default("ABIERTA")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  bankDeposits   BankDeposit[]
  cuts           CashCut[]
  branch         Branch        @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  user           User          @relation(fields: [userId], references: [id], onUpdate: NoAction)
  sales          Sale[]
}

model Customer {
  id          Int      @id @default(autoincrement())
  name        String
  email       String?
  phone       String?
  taxId       String?
  address     String?
  creditLimit Decimal  @default(0) @db.Decimal(18, 2)
  balance     Decimal  @default(0) @db.Decimal(18, 2)
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sales       Sale[]
}

model Sale {
  id             Int          @id @default(autoincrement())
  invoiceNumber  String       @unique
  branchId       Int
  userId         Int
  customerId     Int?
  cashSessionId  Int?
  totalAmount    Decimal      @db.Decimal(18, 2)
  taxAmount      Decimal      @db.Decimal(18, 2)
  discountAmount Decimal      @default(0) @db.Decimal(18, 2)
  paymentMethod  String
  cashReceived   Decimal?     @db.Decimal(18, 2)
  changeGiven    Decimal?     @db.Decimal(18, 2)
  status         String       @default("COMPLETADA")
  pointsEarned   Int          @default(0)
  pointsRedeemed Int          @default(0)
  pointsDiscount Decimal      @default(0) @db.Decimal(18, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  cfdiEmail      String?
  cfdiUuid       String?
  cardType       String?
  branch         Branch       @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  cashSession    CashSession? @relation(fields: [cashSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer       Customer?    @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           User         @relation(fields: [userId], references: [id], onUpdate: NoAction)
  saleDetails    SaleDetail[]
}

model SaleDetail {
  id             Int     @id @default(autoincrement())
  saleId         Int
  productId      Int
  quantity       Int
  unitPrice      Decimal @db.Decimal(18, 2)
  costPrice      Decimal @db.Decimal(18, 2)
  taxAmount      Decimal @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  promotionId    Int?
  promotionLabel String?
  product        Product @relation(fields: [productId], references: [id], onUpdate: NoAction)
  sale           Sale    @relation(fields: [saleId], references: [id], onUpdate: NoAction)
}

model BankDeposit {
  id            Int         @id @default(autoincrement())
  accountNumber String
  targetName    String
  amount        Decimal     @db.Decimal(18, 2)
  paymentType   String
  comments      String?
  cashSessionId Int
  branchId      Int
  createdAt     DateTime    @default(now())
  branch        Branch      @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  cashSession   CashSession @relation(fields: [cashSessionId], references: [id], onUpdate: NoAction)
}

model PromotionType {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  promotions  Promotion[]
}

model Promotion {
  id              Int                @id @default(autoincrement())
  name            String
  description     String?
  promotionTypeId Int
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean            @default(true)
  value           Decimal?           @db.Decimal(18, 2)
  minQuantity     Int?
  payQuantity     Int?
  specialPrice    Decimal?           @db.Decimal(18, 2)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  promotionType   PromotionType      @relation(fields: [promotionTypeId], references: [id], onUpdate: NoAction)
  products        PromotionProduct[]
}

model PromotionProduct {
  id          Int       @id @default(autoincrement())
  promotionId Int
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onUpdate: NoAction)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onUpdate: NoAction)

  @@unique([promotionId, productId])
}

model CashCut {
  id              Int         @id @default(autoincrement())
  cashSessionId   Int
  createdAt       DateTime    @default(now(), map: "DF__CashCut__created__4B7734FF")
  totalSales      Decimal     @db.Decimal(18, 2)
  totalCash       Decimal     @db.Decimal(18, 2)
  totalCreditCard Decimal     @db.Decimal(18, 2)
  totalDebitCard  Decimal     @db.Decimal(18, 2)
  totalRefunds    Decimal     @db.Decimal(18, 2)
  netTotal        Decimal     @db.Decimal(18, 2)
  cutNumber       Int
  cashSession     CashSession @relation(fields: [cashSessionId], references: [id], onUpdate: NoAction)
}
