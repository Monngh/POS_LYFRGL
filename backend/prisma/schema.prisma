generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Branch {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  address         String?
  phone           String?
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bankDeposits    BankDeposit[]
  cashSessions    CashSession[]
  inventories     Inventory[]
  kardexEntries   Kardex[]
  sales           Sale[]
  users           User[]
  purchaseOrders  PurchaseOrder[]  @relation("purchaseOrdersBranch")
  reportAuditLogs ReportAuditLog[]
  authAuditLogs   AuthAuditLog[]
  parkedSales     ParkedSale[]
}

model User {
  id                     Int               @id @default(autoincrement())
  email                  String            @unique
  passwordHash           String
  pinCode                String?
  name                   String
  role                   String
  active                 Boolean           @default(true)
  phone                  String?
  baseSalary             Decimal?          @db.Decimal(18, 2)
  commissionRate         Decimal?          @db.Decimal(18, 4)
  branchId               Int
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  // Segundo factor WebAuthn (Windows Hello / huella / llave de seguridad) para ADMIN/GERENTE.
  // Aditivo y opcional: usuarios sin credencial registrada la enrolan en su próximo inicio de sesión.
  webauthnCredentialId   String?           @db.VarChar(500)
  webauthnPublicKey      String?           @db.VarChar(1000)
  webauthnCounter        Int?              @default(0)
  webauthnTransports     String?           @db.VarChar(200)
  webauthnRegisteredAt   DateTime?
  otpCode                String?           @db.NVarChar(6)
  otpExpiresAt           DateTime?
  bankDeposits           BankDeposit[]
  cashSessions           CashSession[]
  kardexEntries          Kardex[]
  returns                Return[]          @relation("UserReturns")
  authorizedReturns      Return[]          @relation("UserAuthorizedReturns")
  sales                  Sale[]
  branch                 Branch            @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  purchaseOrdersCreated  PurchaseOrder[]   @relation("purchaseCreatedBy")
  purchaseOrdersReceived PurchaseOrder[]   @relation("purchaseReceivedBy")
  reportAuditLogs        ReportAuditLog[]
  authAuditLogs          AuthAuditLog[]
  priceAdjustments       PriceAdjustment[]
  parkedSales            ParkedSale[]
}

model Product {
  id               Int      @id @default(autoincrement())
  sku              String   @unique
  barcode          String?  @unique
  name             String
  description      String?
  costPrice        Decimal  @db.Decimal(18, 2)
  sellPrice        Decimal  @db.Decimal(18, 2)
  active           Boolean  @default(true)
  isReturnable     Boolean  @default(true)
  returnWindowDays Int      @default(30)
  trackingType     String   @default("NONE")
  satProductKey    String   @default("01010101")
  satUnitKey       String   @default("H87")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relación anterior: se conserva temporalmente
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Nueva relación: permitirá varias categorías
  categories ProductCategory[]

  inventories            Inventory[]
  kardexEntries          Kardex[]
  promotionProducts      PromotionProduct[]
  saleDetails            SaleDetail[]
  returnDetails          ReturnDetail[]
  productTaxes           ProductTax[]
  purchaseDetails        PurchaseDetail[]        @relation("purchaseDetails")
  suppliers              SupplierProduct[]
  priceLists             PriceListProduct[]
  priceAdjustmentDetails PriceAdjustmentDetail[]
}

model Inventory {
  id        Int     @id @default(autoincrement())
  productId Int
  branchId  Int
  quantity  Int     @default(0)
  minStock  Int     @default(5)
  maxStock  Int     @default(100)
  branch    Branch  @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  product   Product @relation(fields: [productId], references: [id], onUpdate: NoAction)

  @@unique([productId, branchId])
}

model Kardex {
  id              Int            @id @default(autoincrement())
  productId       Int
  branchId        Int
  userId          Int
  quantityChange  Int
  balanceAfter    Int
  movementType    String
  reason          String?
  purchaseOrderId Int?
  createdAt       DateTime       @default(now())
  branch          Branch         @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  product         Product        @relation(fields: [productId], references: [id], onUpdate: NoAction)
  user            User           @relation(fields: [userId], references: [id], onUpdate: NoAction)
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onUpdate: NoAction, onDelete: SetNull)
}

model CashSession {
  id               Int           @id @default(autoincrement())
  branchId         Int
  userId           Int
  openedAt         DateTime      @default(now())
  closedAt         DateTime?
  initialAmount    Decimal       @db.Decimal(18, 2)
  expectedAmount   Decimal       @db.Decimal(18, 2)
  declaredAmount   Decimal?      @db.Decimal(18, 2)
  difference       Decimal?      @db.Decimal(18, 2)
  cashIn           Decimal       @default(0) @db.Decimal(18, 2)
  cashOut          Decimal       @default(0) @db.Decimal(18, 2)
  status           String        @default("ABIERTA")
  deviceId         String?       @db.VarChar(64)
  forceCloseReason String?       @db.VarChar(500)
  forcedByUserId   Int?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  bankDeposits     BankDeposit[]
  cuts             CashCut[]
  branch           Branch        @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  user             User          @relation(fields: [userId], references: [id], onUpdate: NoAction)
  sales            Sale[]
  returns          Return[]

  @@index([userId, status])
}

model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  email        String?
  phone        String?
  passwordHash String?
  taxId        String?
  address      String?
  creditLimit  Decimal       @default(0) @db.Decimal(18, 2)
  balance      Decimal       @default(0) @db.Decimal(18, 2)
  points       Int           @default(0)
  zipCode      String?
  taxRegime    String?
  cfdiUse      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  priceListId  Int?
  priceList    PriceList?    @relation(fields: [priceListId], references: [id])
  sales        Sale[]
  storeCredits StoreCredit[]
  parkedSales  ParkedSale[]

  @@index([taxId])
}

model Sale {
  id                   Int           @id @default(autoincrement())
  invoiceNumber        String        @unique
  branchId             Int
  userId               Int
  customerId           Int?
  cashSessionId        Int?
  totalAmount          Decimal       @db.Decimal(18, 2)
  taxAmount            Decimal       @db.Decimal(18, 2)
  discountAmount       Decimal       @default(0) @db.Decimal(18, 2)
  paymentMethod        String
  cashReceived         Decimal?      @db.Decimal(18, 2)
  changeGiven          Decimal?      @db.Decimal(18, 2)
  status               String        @default("COMPLETADA")
  pointsEarned         Int           @default(0)
  pointsRedeemed       Int           @default(0)
  pointsDiscount       Decimal       @default(0) @db.Decimal(18, 2)
  cfdiEmail            String?
  cfdiUuid             String?
  cardType             String?
  mercadoPagoPaymentId String?
  mercadoPagoReference String?
  mercadoPagoStatus    String?
  mercadoPagoQrData    String?       @db.VarChar(Max)
  refundStatus         String?
  refundId             String?
  refundDate           DateTime?
  refundAmount         Decimal?      @db.Decimal(18, 2)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  branch               Branch        @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  cashSession          CashSession?  @relation(fields: [cashSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer             Customer?     @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                 User          @relation(fields: [userId], references: [id], onUpdate: NoAction)
  saleDetails          SaleDetail[]
  returns              Return[]
  payments             SalePayment[]
}

model SaleDetail {
  id              Int             @id @default(autoincrement())
  saleId          Int
  productId       Int
  quantity        Int
  unitPrice       Decimal         @db.Decimal(18, 2)
  costPrice       Decimal         @db.Decimal(18, 2)
  taxAmount       Decimal         @db.Decimal(18, 2)
  discountAmount  Decimal         @default(0) @db.Decimal(18, 2)
  promotionId     Int?
  promotionLabel  String?
  serialNumber    String?
  batchNumber     String?
  product         Product         @relation(fields: [productId], references: [id], onUpdate: NoAction)
  sale            Sale            @relation(fields: [saleId], references: [id], onUpdate: NoAction)
  returnDetails   ReturnDetail[]
  saleDetailTaxes SaleDetailTax[]
}

model SalePayment {
  id            Int      @id @default(autoincrement())
  saleId        Int
  paymentMethod String // EFECTIVO, TARJETA, TRANSFERENCIA, STORE_CREDIT, MIXTO
  amount        Decimal  @db.Decimal(18, 2)
  reference     String? // UUID, etc.
  createdAt     DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
}

model BankDeposit {
  id                   Int         @id @default(autoincrement())
  accountNumber        String
  targetName           String
  amount               Decimal     @db.Decimal(18, 2)
  paymentType          String
  comments             String?
  reference            String?
  status               String      @default("PENDING")
  mercadoPagoPaymentId String?
  mercadoPagoStatus    String?
  ticketUrl            String?     @db.VarChar(Max)
  cashSessionId        Int
  userId               Int
  branchId             Int
  confirmedAt          DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  createdAt            DateTime    @default(now())
  branch               Branch      @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cashSession          CashSession @relation(fields: [cashSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                 User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model PromotionType {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  promotions  Promotion[]
}

model Promotion {
  id              Int                @id @default(autoincrement())
  name            String
  description     String?
  promotionTypeId Int
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean            @default(true)
  value           Decimal?           @db.Decimal(18, 2)
  minQuantity     Int?
  payQuantity     Int?
  specialPrice    Decimal?           @db.Decimal(18, 2)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  promotionType   PromotionType      @relation(fields: [promotionTypeId], references: [id], onUpdate: NoAction)
  products        PromotionProduct[]
}

model PromotionProduct {
  id          Int       @id @default(autoincrement())
  promotionId Int
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onUpdate: NoAction)
  promotion   Promotion @relation(fields: [promotionId], references: [id], onUpdate: NoAction)

  @@unique([promotionId, productId])
}

model CashCut {
  id              Int         @id @default(autoincrement())
  cashSessionId   Int
  createdAt       DateTime    @default(now(), map: "DF__CashCut__created__4B7734FF")
  totalSales      Decimal     @db.Decimal(18, 2)
  totalCash       Decimal     @db.Decimal(18, 2)
  totalCreditCard Decimal     @db.Decimal(18, 2)
  totalDebitCard  Decimal     @db.Decimal(18, 2)
  totalRefunds    Decimal     @db.Decimal(18, 2)
  netTotal        Decimal     @db.Decimal(18, 2)
  cutNumber       Int
  cashSession     CashSession @relation(fields: [cashSessionId], references: [id], onUpdate: NoAction)
}

model Return {
  id             Int            @id @default(autoincrement())
  returnNumber   String         @unique
  saleId         Int
  userId         Int
  authorizedById Int
  reason         String
  type           String
  totalRefunded  Decimal        @db.Decimal(18, 2)
  paymentMethod  String
  cashSessionId  Int?
  cfdiUuid       String?
  exchangeSaleId Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  sale           Sale           @relation(fields: [saleId], references: [id], onUpdate: NoAction)
  user           User           @relation("UserReturns", fields: [userId], references: [id], onUpdate: NoAction)
  authorizedBy   User           @relation("UserAuthorizedReturns", fields: [authorizedById], references: [id], onUpdate: NoAction)
  cashSession    CashSession?   @relation(fields: [cashSessionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  returnDetails  ReturnDetail[]
}

model ReturnDetail {
  id             Int        @id @default(autoincrement())
  returnId       Int
  productId      Int
  saleDetailId   Int
  quantity       Int
  unitPrice      Decimal    @db.Decimal(18, 2)
  taxAmount      Decimal    @db.Decimal(18, 2)
  discountAmount Decimal    @db.Decimal(18, 2)
  destination    String
  serialNumber   String?
  batchNumber    String?
  return         Return     @relation(fields: [returnId], references: [id], onUpdate: NoAction)
  product        Product    @relation(fields: [productId], references: [id], onUpdate: NoAction)
  saleDetail     SaleDetail @relation(fields: [saleDetailId], references: [id], onUpdate: NoAction)
}

model StoreCredit {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  amount     Decimal   @db.Decimal(18, 2)
  remaining  Decimal   @db.Decimal(18, 2)
  active     Boolean   @default(true)
  customerId Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model TaxType {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  description     String?
  rate            Decimal         @db.Decimal(18, 4)
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  productTaxes    ProductTax[]
  saleDetailTaxes SaleDetailTax[]
}

model ProductTax {
  id        Int     @id @default(autoincrement())
  productId Int
  taxTypeId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taxType   TaxType @relation(fields: [taxTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([productId, taxTypeId])
}

model SaleDetailTax {
  id           Int        @id @default(autoincrement())
  saleDetailId Int
  taxTypeId    Int
  taxName      String
  taxRate      Decimal    @db.Decimal(18, 4)
  taxAmount    Decimal    @db.Decimal(18, 2)
  saleDetail   SaleDetail @relation(fields: [saleDetailId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  taxType      TaxType    @relation(fields: [taxTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Supplier {
  id             Int               @id @default(autoincrement())
  name           String            @unique
  rfc            String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zipCode        String?
  contactName    String?
  active         Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  purchaseOrders PurchaseOrder[]
  products       SupplierProduct[]

  @@index([name])
}

model SupplierProduct {
  id         Int      @id @default(autoincrement())
  supplierId Int
  productId  Int
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([supplierId, productId])
  @@index([productId])
}

model PurchaseOrder {
  id             Int              @id @default(autoincrement())
  supplierId     Int
  branchId       Int
  reference      String
  purchaseDate   DateTime         @default(now())
  expectedDate   DateTime?
  subtotal       Decimal          @default(0) @db.Decimal(18, 2)
  tax            Decimal          @default(0) @db.Decimal(18, 2)
  total          Decimal          @default(0) @db.Decimal(18, 2)
  status         String           @default("PENDIENTE")
  notes          String?
  createdBy      Int
  receivedBy     Int?
  receivedDate   DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  supplier       Supplier         @relation(fields: [supplierId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  branch         Branch           @relation("purchaseOrdersBranch", fields: [branchId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdByUser  User             @relation("purchaseCreatedBy", fields: [createdBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  receivedByUser User?            @relation("purchaseReceivedBy", fields: [receivedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  details        PurchaseDetail[]
  kardexEntries  Kardex[]

  @@index([supplierId])
  @@index([branchId])
  @@index([status])
}

model PurchaseDetail {
  id              Int           @id @default(autoincrement())
  purchaseOrderId Int
  productId       Int
  quantity        Int
  unitCost        Decimal       @db.Decimal(18, 2)
  subtotal        Decimal       @db.Decimal(18, 2)
  unit            String        @default("PIEZA") @db.NVarChar(50)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product         Product       @relation("purchaseDetails", fields: [productId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([purchaseOrderId])
  @@index([productId])
}

model ReportAuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  branchId   Int?
  reportName String   @db.NVarChar(255)
  reportType String   @db.NVarChar(100)
  filters    String?  @db.NVarChar(Max)
  ipAddress  String?  @db.NVarChar(45)
  createdAt  DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onUpdate: NoAction)
  branch Branch? @relation(fields: [branchId], references: [id], onUpdate: NoAction)
}

// Bitácora de inicios de sesión (accesos) — tanto de cajeros como de admin/gerente.
model AuthAuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  branchId  Int?
  email     String   @db.NVarChar(255)
  name      String   @db.NVarChar(255)
  role      String   @db.NVarChar(50)
  method    String   @db.NVarChar(50) // "PIN", "Contraseña + WebAuthn", "Contraseña + OTP", etc.
  ipAddress String?  @db.NVarChar(45)
  deviceId  String?  @db.NVarChar(64)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onUpdate: NoAction)
  branch Branch? @relation(fields: [branchId], references: [id], onUpdate: NoAction)

  @@index([role, createdAt])
}

// ─── CATEGORÍAS ────────────────────────────────────────────

model Category {
  id          Int     @id @default(autoincrement())
  code        String  @unique @db.VarChar(6)
  name        String  @unique @db.VarChar(30)
  description String? @db.VarChar(50)
  color       String? @db.VarChar(20)
  icon        String? @db.VarChar(50)
  active      Boolean @default(true)

  // Relación anterior: se conserva temporalmente
  // mientras se migra a ProductCategory.
  products Product[]

  // DIVISION | DEPARTMENT | CATEGORY
  level    String @db.VarChar(20)
  parentId Int?

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children Category[] @relation("CategoryHierarchy")

  // Nueva relación para permitir varias categorías por producto.
  productCategories ProductCategory[]

  priceAdjustments PriceAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([level, active])
}

model ProductCategory {
  productId  Int
  categoryId Int
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  category Category @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([productId, categoryId])
  @@index([categoryId])
}

// ─── LISTAS DE PRECIOS ─────────────────────────────────────
model PriceList {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  active      Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products  PriceListProduct[]
  customers Customer[]
}

model PriceListProduct {
  id          Int      @id @default(autoincrement())
  priceListId Int
  productId   Int
  price       Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  priceList PriceList @relation(fields: [priceListId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId])
}

// ─── HISTORIAL DE AJUSTES DE PRECIO ───────────────────────
model PriceAdjustment {
  id Int @id @default(autoincrement())

  // PERCENTAGE | FIXED | EXACT
  type String @db.VarChar(20)

  // INCREASE | DECREASE | SET
  direction String @db.VarChar(20)

  // SELECTED_PRODUCTS | DIVISION | DEPARTMENT | CATEGORY | UNCATEGORIZED
  scope String @db.VarChar(30)

  value          Decimal @db.Decimal(18, 2)
  affectedRows   Int
  belowCostCount Int     @default(0)
  notes          String? @db.VarChar(500)

  appliedAt   DateTime @default(now())
  appliedById Int
  categoryId  Int?

  appliedBy User      @relation(fields: [appliedById], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])

  details PriceAdjustmentDetail[]

  @@index([appliedAt])
  @@index([appliedById])
  @@index([categoryId])
  @@index([scope])
}

model PriceAdjustmentDetail {
  id                Int @id @default(autoincrement())
  priceAdjustmentId Int
  productId         Int

  oldSellPrice      Decimal @db.Decimal(18, 2)
  newSellPrice      Decimal @db.Decimal(18, 2)
  costPriceAtChange Decimal @db.Decimal(18, 2)
  isBelowCost       Boolean @default(false)

  createdAt DateTime @default(now())

  priceAdjustment PriceAdjustment @relation(fields: [priceAdjustmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product         Product         @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([priceAdjustmentId])
  @@index([productId])
}

// ─── VENTAS PAUSADAS (PARKED SALES) ───────────────────────
model ParkedSale {
  id         Int      @id @default(autoincrement())
  userId     Int
  branchId   Int
  customerId Int?
  cartData   String   @db.VarChar(Max)
  total      Decimal  @db.Decimal(18, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onUpdate: NoAction)
  branch   Branch    @relation(fields: [branchId], references: [id], onUpdate: NoAction)
  customer Customer? @relation(fields: [customerId], references: [id], onUpdate: NoAction)

  @@index([userId, branchId])
}
